{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": "frontend/dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|jpg|jpeg|gif|png|svg|webp|woff|woff2|ico)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      }
    ],
    "predeploy": [
      "npm --prefix frontend run build"
    ]
  },
  "auth": {
    "providers": {
      "googleSignIn": {
        "oAuthBrandDisplayName": "Indur Real Estate",
        "supportEmail": "sumanthreddyaleti@gmail.com",
        "authorizedRedirectUris": [
          "http://localhost:5173",
          "https://nizamabad-698d9.firebaseapp.com",
          "https://frontend.vercel.app",
          "https://indur.site",
          "https://www.indur.site"
        ]
      }
    },
    "authorizedDomains": [
      "localhost",
      "nizamabad-698d9.firebaseapp.com",
      "nizamabad-698d9.web.app",
      "frontend.vercel.app",
      "indur.site",
      "www.indur.site"
    ]
  }
}
